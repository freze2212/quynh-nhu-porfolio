{
	"name": "kjc-boss-khanhvy",
	"version": "1.2.2",
	"private": true,
	"scripts": {
		"clean": "node -e \"require('fs').rmSync('.next', { recursive: true, force: true, maxRetries: 10, retryDelay: 150 })\"",
		"dev": "next dev",
		"dev:clean": "npm run clean && next dev",
		"dev:turbopack": "next dev --turbopack",
		"dev:webpack": "next dev",
		"build": "node -e \"require('fs').rmSync('.next', { recursive: true, force: true, maxRetries: 10, retryDelay: 150 })\"; next build",
		"start": "next start",
		"preview": "npx --yes serve@latest out",
		"lint": "next lint",
		"format": "prettier --write .",
		"prepare": "node -e \"if (process.env.CI !== 'true' && process.env.CF_PAGES !== '1') { require('child_process').execSync('husky', { stdio: 'inherit' }) }\"",
		"svgr": "svgr --typescript --icon --title-prop --ref --no-prettier --out-dir src/components/icons src/assets/icons",
		"static": "npm run build"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx}": [
			"eslint --fix",
			"prettier --write"
		]
	},
	"dependencies": {
		"@hookform/resolvers": "^5.0.1",
		"@next/third-parties": "^15.3.3",
		"@radix-ui/react-dialog": "^1.1.14",
		"@tanstack/react-query": "^5.74.4",
		"@vimeo/player": "^2.30.3",
		"axios": "^1.8.4",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cookies-next": "^6.0.0",
		"date-fns": "^4.1.0",
		"husky": "^9.1.7",
		"lucide-react": "^0.539.0",
		"next": "^15.3.3",
		"next-intl": "^4.1.0",
		"next-themes": "^0.4.6",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"react-hook-form": "^7.56.3",
		"react-wrap-balancer": "^1.1.1",
		"swiper": "^11.2.10",
		"tailwind-merge": "^3.2.0",
		"usehooks-ts": "^3.1.1"
	},
	"overrides": {
		"@swc/helpers": "0.5.20"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3",
		"@ianvs/prettier-plugin-sort-imports": "^4.4.1",
		"@svgr/cli": "^8.1.0",
		"@svgr/core": "^8.1.0",
		"@svgr/webpack": "^8.1.0",
		"@tailwindcss/postcss": "^4",
		"@types/node": "^20",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"@types/react-query": "^1.2.8",
		"eslint": "^9",
		"eslint-config-next": "15.3.1",
		"lint-staged": "^16.1.0",
		"prettier": "^3.5.3",
		"prettier-plugin-tailwindcss": "^0.6.11",
		"tailwindcss": "^4",
		"tw-animate-css": "^1.2.5",
		"typescript": "^5"
	}
}
